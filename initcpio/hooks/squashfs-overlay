#!/bin/bash
# squashfs-overlay — mkinitcpio runtime hook
# Mounts squashfs + overlayfs as root when no data disk root is available

run_hook() {
    # Only activate if arch-root-discover set squashfs mode
    case "${ARCH_BOOT_MODE:-}" in
        squashfs|squashfs-provision) ;;
        *) return 0 ;;
    esac

    msg "squashfs-overlay: Setting up squashfs + overlayfs root..."

    local boot_root=""

    # Find the boot disk partition containing the squashfs
    # Try to find by label first, then by scanning
    boot_root=$(blkid -L "archboot" 2>/dev/null || true)
    if [[ -z "$boot_root" ]]; then
        # Scan for the partition containing airootfs.sfs
        for dev in /dev/sda2 /dev/sda1 /dev/nvme0n1p2; do
            if [[ -b "$dev" ]]; then
                mkdir -p /run/archboot
                if mount -o ro "$dev" /run/archboot 2>/dev/null; then
                    if [[ -f /run/archboot/sfs/airootfs.sfs ]]; then
                        boot_root="$dev"
                        umount /run/archboot
                        break
                    fi
                    umount /run/archboot 2>/dev/null || true
                fi
            fi
        done
    fi

    if [[ -z "$boot_root" ]]; then
        msg "squashfs-overlay: ERROR — Cannot find boot partition with squashfs!"
        return 1
    fi

    # Mount the boot partition read-only
    mkdir -p /run/archboot
    mount -o ro "${boot_root}" /run/archboot

    # Mount the squashfs
    mkdir -p /run/archiso/sfs
    mount -o ro,loop /run/archboot/sfs/airootfs.sfs /run/archiso/sfs

    # Create tmpfs for overlay upper + work dirs
    mkdir -p /run/archiso/cowspace
    mount -t tmpfs -o size=75% cowspace /run/archiso/cowspace
    mkdir -p /run/archiso/cowspace/{upper,work}

    # Mount overlayfs as new root
    mount -t overlay overlay \
        -o lowerdir=/run/archiso/sfs,upperdir=/run/archiso/cowspace/upper,workdir=/run/archiso/cowspace/work \
        /new_root

    # Persist boot mode info for userspace services
    mkdir -p /new_root/run/arch-root
    echo "${ARCH_BOOT_MODE}" > /new_root/run/arch-root/boot-mode

    # Pass through raw disk info if present
    if [[ -f /run/arch-root/raw-data-disk ]]; then
        cp /run/arch-root/raw-data-disk /new_root/run/arch-root/raw-data-disk
    fi

    # Prefer TPM-unlocked encrypted storage for persistent log/cache on OS disk.
    local var_img="/run/archboot/crypt/var-store.luks"
    local var_loop=""
    local var_mapper="arch_var"
    local var_mnt="/run/archvar"
    local var_ready=0

    if [[ -f "${var_img}" ]]; then
        var_loop=$(losetup --find --show "${var_img}" 2>/dev/null || true)
        if [[ -n "${var_loop}" ]]; then
            if systemd-cryptsetup attach "${var_mapper}" "${var_loop}" - tpm2-device=auto,tpm2-pcrs=7 2>/dev/null; then
                mkdir -p "${var_mnt}"
                if mount -o compress=zstd:6,noatime "/dev/mapper/${var_mapper}" "${var_mnt}" 2>/dev/null; then
                    mkdir -p "${var_mnt}/log" "${var_mnt}/cache"
                    mount --bind "${var_mnt}/log" /new_root/var/log
                    mount --bind "${var_mnt}/cache" /new_root/var/cache
                    var_ready=1
                    msg "squashfs-overlay: Mounted TPM-encrypted persistent /var/log and /var/cache"
                fi
            fi
        fi
    fi

    # If encrypted container is unavailable, keep logs/cache ephemeral in RAM.
    if [[ "${var_ready}" -eq 0 ]]; then
        mount -t tmpfs -o mode=0755,nosuid,nodev,noexec tmpfs /new_root/var/log 2>/dev/null || true
        mount -t tmpfs -o mode=0755,nosuid,nodev tmpfs /new_root/var/cache 2>/dev/null || true
        msg "squashfs-overlay: Encrypted var store unavailable; using tmpfs for /var/log and /var/cache"
    fi

    msg "squashfs-overlay: Root overlay ready (mode: ${ARCH_BOOT_MODE})"
}
