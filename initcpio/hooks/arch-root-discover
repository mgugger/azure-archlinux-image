#!/bin/bash
# arch-root-discover — mkinitcpio runtime hook
# Discovers attached data disks, checks for LUKS, and sets up root accordingly.
#
# Boot modes:
#   1. LUKS data disk found → unseal with vTPM → mount as root
#   2. Raw data disk found  → flag for first-boot provisioning, use squashfs
#   3. No data disk         → use squashfs overlay as root

run_hook() {
    local data_disk=""
    local luks_found=0
    local raw_found=0

    msg "arch-root-discover: Scanning for data disks..."

    # Azure data disks appear under /dev/disk/azure/scsi1/
    # Wait briefly for disk subsystem to settle
    udevadm settle --timeout=10 2>/dev/null || sleep 3

    # Strategy: look for Azure data disk LUNs, then fall back to scanning /dev/sd*
    # Azure SCSI data disks: /dev/disk/azure/scsi1/lun*
    if [[ -d /dev/disk/azure/scsi1 ]]; then
        for lun in /dev/disk/azure/scsi1/lun*; do
            [[ -b "$lun" ]] || continue
            data_disk=$(readlink -f "$lun")
            break
        done
    fi

    # Fallback: scan for non-root SCSI disks (skip sda which is the OS disk)
    if [[ -z "$data_disk" ]]; then
        for dev in /dev/sd{b,c,d,e}; do
            [[ -b "$dev" ]] || continue
            data_disk="$dev"
            break
        done
    fi

    # Also check NVMe data disks (some Azure VM sizes use NVMe)
    if [[ -z "$data_disk" ]]; then
        for dev in /dev/nvme{1,2,3}n1; do
            [[ -b "$dev" ]] || continue
            data_disk="$dev"
            break
        done
    fi

    if [[ -z "$data_disk" ]]; then
        msg "arch-root-discover: No data disk found. Booting into squashfs."
        export ARCH_BOOT_MODE="squashfs"
        return 0
    fi

    msg "arch-root-discover: Found data disk: ${data_disk}"

    # Check if disk has a LUKS header
    if cryptsetup isLuks "${data_disk}" 2>/dev/null || \
       cryptsetup isLuks "${data_disk}p1" 2>/dev/null || \
       cryptsetup isLuks "${data_disk}1" 2>/dev/null; then

        luks_found=1
        local luks_part="${data_disk}"
        # Check partitions too
        for suffix in "p1" "1" ""; do
            if cryptsetup isLuks "${data_disk}${suffix}" 2>/dev/null; then
                luks_part="${data_disk}${suffix}"
                break
            fi
        done

        msg "arch-root-discover: LUKS partition found: ${luks_part}"

        # Try vTPM first, then fall back to passphrase via serial console
        local unlocked=0

        msg "arch-root-discover: Attempting vTPM unseal..."
        if systemd-cryptsetup attach arch_root "${luks_part}" - tpm2-device=auto 2>/dev/null; then
            msg "arch-root-discover: vTPM unlock successful."
            unlocked=1
        else
            msg "arch-root-discover: vTPM unlock failed."
            msg "arch-root-discover: Falling back to passphrase (serial console)..."

            # Prompt on serial console (/dev/ttyS0) for Azure serial console access
            local attempts=0
            local max_attempts=3
            while [[ $attempts -lt $max_attempts ]]; do
                attempts=$((attempts + 1))
                msg "arch-root-discover: Passphrase attempt ${attempts}/${max_attempts}"

                local passphrase
                passphrase=$(systemd-ask-password --timeout=120 \
                    "Enter LUKS passphrase for ${luks_part} (attempt ${attempts}/${max_attempts}):" 2>/dev/null || true)

                if [[ -n "$passphrase" ]]; then
                    if echo -n "$passphrase" | cryptsetup open --type luks2 "${luks_part}" arch_root - 2>/dev/null; then
                        msg "arch-root-discover: Passphrase unlock successful."
                        unlocked=1
                        break
                    else
                        msg "arch-root-discover: Wrong passphrase."
                    fi
                fi
            done

            if [[ $unlocked -eq 0 ]]; then
                msg "arch-root-discover: All unlock attempts failed. Booting into squashfs."
            fi
        fi

        if [[ $unlocked -eq 1 ]]; then
            # Mount the BTRFS root
            if mount -o compress=zstd:6,noatime,subvol=@ /dev/mapper/arch_root /new_root; then
                # Mount subvolumes
                mkdir -p /new_root/{home,root,srv,var/log,var/cache,var/tmp}
                mount -o compress=zstd:6,noatime,nosuid,nodev,subvol=@home /dev/mapper/arch_root /new_root/home 2>/dev/null || true
                mount -o compress=zstd:6,noatime,subvol=@root /dev/mapper/arch_root /new_root/root 2>/dev/null || true
                mount -o compress=zstd:6,noatime,subvol=@srv /dev/mapper/arch_root /new_root/srv 2>/dev/null || true
                mount -o compress=zstd:6,noatime,nosuid,noexec,nodev,subvol=@log /dev/mapper/arch_root /new_root/var/log 2>/dev/null || true
                mount -o compress=zstd:6,noatime,nosuid,nodev,subvol=@cache /dev/mapper/arch_root /new_root/var/cache 2>/dev/null || true
                mount -o compress=zstd:6,noatime,nosuid,noexec,nodev,subvol=@vartmp /dev/mapper/arch_root /new_root/var/tmp 2>/dev/null || true

                export ARCH_BOOT_MODE="data-disk"
                msg "arch-root-discover: Data disk root mounted successfully."
                return 0
            else
                msg "arch-root-discover: BTRFS mount failed. Falling back to squashfs."
                cryptsetup close arch_root 2>/dev/null || true
            fi
        fi
    fi

    # If we get here with a data disk but no LUKS, it's raw/unformatted
    if [[ "$luks_found" -eq 0 ]]; then
        msg "arch-root-discover: Raw/unformatted data disk detected: ${data_disk}"
        # Store disk path for the first-boot provisioning service
        mkdir -p /run/arch-root
        echo "${data_disk}" > /run/arch-root/raw-data-disk
        export ARCH_BOOT_MODE="squashfs-provision"
    else
        export ARCH_BOOT_MODE="squashfs"
    fi

    return 0
}
